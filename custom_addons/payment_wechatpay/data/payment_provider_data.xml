<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="payment_provider_wechatpay" model="payment.provider">
        <field name="name">微信支付</field>
        <field name="code">wechatpay</field>
        <field name="state">disabled</field>
        <field name="redirect_form_view_id" ref="payment_wechatpay.redirect_form"/>
        <field name="payment_method_ids" eval="[Command.set([ref('payment_wechatpay.payment_method_wechatpay')])]"/>
        <field name="pending_msg">请打开微信扫一扫完成支付。支付成功后订单会自动确认。</field>
        <field name="done_msg">微信支付已完成。</field>
        <field name="cancel_msg">微信支付已取消。</field>
    </record>
</odoo>
