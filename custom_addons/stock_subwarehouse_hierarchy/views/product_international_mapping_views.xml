<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_international_mapping_import_wizard" model="ir.ui.view">
        <field name="name">stock.subwarehouse.product.international.mapping.import.wizard.form</field>
        <field name="model">stock.subwarehouse.product.international.mapping.import.wizard</field>
        <field name="arch" type="xml">
            <form string="&#23548;&#20837;&#33521;&#25991;&#21517;&#31216;&#19982;&#32654;&#20803;&#20215;&#26684;">
                <sheet>
                    <group>
                        <field name="import_file" filename="import_filename"/>
                        <field name="import_filename" invisible="1"/>
                    </group>
                    <div class="text-muted">
                        &#20351;&#29992;&#8220;product_code_pattern&#8221;&#19982;&#20135;&#21697;&#20869;&#37096;&#32534;&#21495;&#20005;&#26684;&#21305;&#37197;&#12290;&#27599;&#20010; * &#20165;&#34920;&#31034; 1 &#20010;&#20219;&#24847;&#23383;&#31526;&#12290;&#23548;&#20837;&#8220;&#33521;&#25991;&#21517;&#31216;&#65288;&#25110; PRODUCT&#65289;&#8221;&#21644;&#8220;USD &#20215;&#26684;&#65288;&#25110; RETAIL PRICE (USD)&#65289;&#8221;&#65292;&#31354;&#30333;&#27169;&#24335;&#20250;&#34987;&#24573;&#30053;&#12290;
                    </div>
                </sheet>
                <footer>
                    <button name="action_import_mapping" type="object" string="&#23548;&#20837;&#24182;&#26356;&#26032;" class="btn-primary"/>
                    <button special="cancel" string="&#21462;&#28040;"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_product_international_mapping" model="ir.actions.act_window">
        <field name="name">&#23548;&#20837;&#33521;&#25991;&#21517;&#31216;&#19982;&#32654;&#20803;&#20215;&#26684;</field>
        <field name="res_model">stock.subwarehouse.product.international.mapping.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list,form</field>
    </record>

    <record id="view_product_website_code_mapping_list" model="ir.ui.view">
        <field name="name">stock.subwarehouse.product.website.code.mapping.list</field>
        <field name="model">stock.subwarehouse.product.website.code.mapping</field>
        <field name="arch" type="xml">
            <list string="英文网站编号价格规则">
                <field name="product_code_pattern"/>
                <field name="english_name"/>
                <field name="usd_price"/>
                <field name="specificity" optional="hide"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_product_website_code_mapping_form" model="ir.ui.view">
        <field name="name">stock.subwarehouse.product.website.code.mapping.form</field>
        <field name="model">stock.subwarehouse.product.website.code.mapping</field>
        <field name="arch" type="xml">
            <form string="英文网站编号价格规则">
                <header>
                    <button name="action_apply_to_products" type="object" string="应用到匹配产品" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="product_code_pattern"/>
                        <field name="english_name"/>
                        <field name="usd_price"/>
                        <field name="active"/>
                        <field name="specificity" readonly="1"/>
                    </group>
                    <div class="text-muted">
                        &#27599;&#20010; * &#20165;&#34920;&#31034; 1 &#20010;&#20219;&#24847;&#23383;&#31526;&#12290;&#20363;&#22914; ******S2-**100-******* &#21482;&#21305;&#37197;&#20855;&#26377;&#30456;&#21516;&#23383;&#31526;&#38271;&#24230;&#30340;&#20135;&#21697;&#20869;&#37096;&#32534;&#21495;&#12290;
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_website_code_mapping" model="ir.actions.act_window">
        <field name="name">英文网站编号价格规则</field>
        <field name="res_model">stock.subwarehouse.product.website.code.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="product_template_list_international_mapping_fields" model="ir.ui.view">
        <field name="name">product.template.list.international.mapping.fields</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="account.product_template_list_view_sellable_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_website_english_name" string="&#33521;&#25991;&#32593;&#31449;&#21517;&#31216;" optional="show"/>
                <field name="x_website_code_mapping_id" string="&#33521;&#25991;&#32593;&#31449;&#32534;&#21495;&#35268;&#21017;" optional="show"/>
                <field name="x_website_usd_price" string="&#33521;&#25991;&#32593;&#31449;&#20215;&#26684; (USD)" optional="show"/>
            </xpath>
            <xpath expr="//list" position="inside">
                <header>
                    <button
                        name="%(action_import_product_international_mapping)d"
                        type="action"
                        string="&#23548;&#20837;&#33521;&#25991;&#21517;&#31216;&#19982;&#32654;&#20803;&#20215;&#26684;"
                        class="btn-secondary"
                        display="always"/>
                    <button
                        name="%(action_product_website_code_mapping)d"
                        type="action"
                        string="&#31649;&#29702;&#32534;&#21495;&#20215;&#26684;&#35268;&#21017;"
                        class="btn-secondary"
                        display="always"/>
                </header>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_international_mapping_fields" model="ir.ui.view">
        <field name="name">product.template.form.international.mapping.fields</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']" position="after">
                <page name="international_website" string="&#22269;&#38469;&#32593;&#31449;">
                    <group string="&#20013;&#33521;&#20135;&#21697;&#26144;&#23556;">
                        <field name="name" string="&#20013;&#25991;&#20135;&#21697;&#21517;&#31216;"/>
                        <field name="x_website_english_name"/>
                        <field name="x_website_code_mapping_id"/>
                        <field name="x_website_usd_price"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
