<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_international_mapping_import_wizard" model="ir.ui.view">
        <field name="name">stock.subwarehouse.product.international.mapping.import.wizard.form</field>
        <field name="model">stock.subwarehouse.product.international.mapping.import.wizard</field>
        <field name="arch" type="xml">
            <form string="&#23548;&#20837;&#33521;&#25991;&#21517;&#31216;&#19982;&#32654;&#20803;&#20215;&#26684;">
                <sheet>
                    <group>
                        <field name="import_file" filename="import_filename"/>
                        <field name="import_filename" invisible="1"/>
                    </group>
                    <div class="text-muted">
                        &#25903;&#25345;&#24403;&#21069; SUN &#22269;&#38469;&#20215;&#26684;&#34920;&#65306;&#20197;&#8220;&#21517;&#31216;&#8221;&#21305;&#37197;&#20013;&#25991;&#20135;&#21697;&#21517;&#65292;&#23548;&#20837;&#8220;PRODUCT&#8221;&#21644;&#8220;RETAIL PRICE (USD)&#8221;&#12290;&#26410;&#21305;&#37197;&#30340;&#20135;&#21697;&#19981;&#20250;&#34987;&#26356;&#25913;&#12290;
                    </div>
                </sheet>
                <footer>
                    <button name="action_import_mapping" type="object" string="&#23548;&#20837;&#24182;&#26356;&#26032;" class="btn-primary"/>
                    <button special="cancel" string="&#21462;&#28040;"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_product_international_mapping" model="ir.actions.act_window">
        <field name="name">&#23548;&#20837;&#33521;&#25991;&#21517;&#31216;&#19982;&#32654;&#20803;&#20215;&#26684;</field>
        <field name="res_model">stock.subwarehouse.product.international.mapping.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list,form</field>
    </record>

    <record id="product_template_list_international_mapping_fields" model="ir.ui.view">
        <field name="name">product.template.list.international.mapping.fields</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="account.product_template_list_view_sellable_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_website_english_name" string="&#33521;&#25991;&#32593;&#31449;&#21517;&#31216;" optional="show"/>
                <field name="x_website_usd_price" string="&#33521;&#25991;&#32593;&#31449;&#20215;&#26684; (USD)" optional="show"/>
            </xpath>
            <xpath expr="//list" position="inside">
                <header>
                    <button
                        name="%(action_import_product_international_mapping)d"
                        type="action"
                        string="&#23548;&#20837;&#33521;&#25991;&#21517;&#31216;&#19982;&#32654;&#20803;&#20215;&#26684;"
                        class="btn-secondary"
                        display="always"/>
                </header>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_international_mapping_fields" model="ir.ui.view">
        <field name="name">product.template.form.international.mapping.fields</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']" position="after">
                <page name="international_website" string="&#22269;&#38469;&#32593;&#31449;">
                    <group string="&#20013;&#33521;&#20135;&#21697;&#26144;&#23556;">
                        <field name="name" string="&#20013;&#25991;&#20135;&#21697;&#21517;&#31216;"/>
                        <field name="x_website_english_name"/>
                        <field name="x_website_usd_price"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
