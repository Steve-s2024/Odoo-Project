<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_source_inventory" model="ir.ui.view">
        <field name="name">sale.order.form.source.inventory</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_website_payments"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-credit-card"
                    invisible="x_website_payment_count == 0"
                    groups="account.group_account_invoice">
                    <field name="x_website_payment_count" widget="statinfo" string="网站收款"/>
                </button>
                <button
                    name="action_refund_website_payment"
                    type="object"
                    string="微信退款"
                    class="oe_stat_button"
                    icon="fa-undo"
                    invisible="x_website_payment_state != 'paid' or x_website_payment_count != 1"
                    groups="account.group_account_invoice"/>
                <button name="action_view_website_refund_requests" type="object" class="oe_stat_button" icon="fa-undo" invisible="x_website_refund_request_count == 0" groups="account.group_account_invoice">
                    <field name="x_website_refund_request_count" widget="statinfo" string="退款申请"/>
                </button>
            </xpath>
            <xpath expr="//sheet//field[@name='user_id']" position="after">
                <field name="x_platform"/>
                <field name="x_channel"/>
                <field name="x_sale_nature"/>
                <field name="x_finance_remark"/>
                <field name="x_website_payment_state" readonly="1" invisible="not website_id"/>
                <field name="x_website_payment_reference" readonly="1" invisible="not website_id"/>
                <field name="x_website_stock_reserved_until" readonly="1" invisible="not website_id or state not in ['draft', 'sent']"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//form//field[@name='product_id']" position="after">
                <field name="x_product_default_code" readonly="1"/>
                <field name="x_import_product_name"/>
                <field name="x_color"/>
                <field name="x_size"/>
                <field name="x_flex"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='product_template_id']" position="after">
                <field name="x_product_default_code" readonly="1" optional="show"/>
                <field name="x_import_product_name" optional="show"/>
                <field name="x_color" optional="show"/>
                <field name="x_size" optional="show"/>
                <field name="x_flex" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//form//div[@name='ordered_qty']" position="after">
                <field name="is_storable" invisible="1"/>
                <field name="x_eligible_source_location_ids" invisible="1"/>
                <field
                    name="x_source_location_id"
                    options="{'no_create': True}"
                    context="{
                        'sale_source_inventory_filter': True,
                        'sale_source_product_id': product_id,
                        'sale_source_product_uom_id': product_uom_id,
                        'sale_source_product_uom_qty': product_uom_qty,
                        'sale_source_company_id': parent.company_id,
                    }"
                    readonly="parent.state not in ['draft', 'sent'] or is_downpayment"
                    invisible="display_type or not is_storable"/>
                <field
                    name="x_source_available_qty"
                    readonly="1"
                    invisible="display_type or not is_storable"/>
                <field
                    name="x_source_can_fulfill"
                    readonly="1"
                    invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom_qty']" position="after">
                <field name="is_storable" column_invisible="1"/>
                <field name="x_eligible_source_location_ids" invisible="1"/>
                <field
                    name="x_source_location_id"
                    options="{'no_create': True}"
                    context="{
                        'sale_source_inventory_filter': True,
                        'sale_source_product_id': product_id,
                        'sale_source_product_uom_id': product_uom_id,
                        'sale_source_product_uom_qty': product_uom_qty,
                        'sale_source_company_id': parent.company_id,
                    }"
                    readonly="parent.state not in ['draft', 'sent'] or is_downpayment"
                    invisible="display_type or not is_storable"
                    optional="show"/>
                <field
                    name="x_source_available_qty"
                    readonly="1"
                    invisible="display_type or not is_storable"
                    decoration-danger="not x_source_can_fulfill"
                    optional="show"/>
                <field name="x_source_can_fulfill" column_invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
