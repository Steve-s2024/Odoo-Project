<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="collections_page" name="SUN Collections Page">
        <t t-call="website.layout">
            <t t-set="additional_title" t-value="'Collections' if is_english else '产品系列'"/>
            <main id="wrap" class="x_collections_page">
                <style>
                    .x_collections_page {
                        background: #fff;
                        color: #111;
                    }
                    .x_collections_inner {
                        width: min(1180px, calc(100% - 32px));
                        margin: 0 auto;
                    }
                    .x_collections_hero {
                        padding: 72px 0 42px;
                        border-bottom: 1px solid #e7e7e7;
                    }
                    .x_collections_eyebrow {
                        margin: 0 0 14px;
                        font-weight: 900;
                        letter-spacing: .08em;
                        text-transform: uppercase;
                        color: #777;
                    }
                    .x_collections_hero h1 {
                        max-width: 860px;
                        margin: 0;
                        font-size: clamp(2.4rem, 6vw, 5.5rem);
                        line-height: .95;
                        font-weight: 950;
                        letter-spacing: 0;
                        text-transform: uppercase;
                    }
                    .x_collections_hero p {
                        max-width: 720px;
                        margin: 22px 0 0;
                        color: #555;
                        font-size: 1.08rem;
                        line-height: 1.7;
                    }
                    .x_collections_grid {
                        display: grid;
                        grid-template-columns: repeat(3, minmax(0, 1fr));
                        gap: 1px;
                        padding: 42px 0 72px;
                        background: #ddd;
                    }
                    .x_collection_card {
                        display: grid;
                        min-height: 320px;
                        align-content: end;
                        padding: 28px;
                        background: #fff;
                        color: #111;
                        text-decoration: none;
                    }
                    .x_collection_card h2 {
                        margin: 0;
                        font-size: clamp(1.45rem, 3vw, 2.35rem);
                        line-height: 1;
                        font-weight: 950;
                        letter-spacing: 0;
                        text-transform: uppercase;
                    }
                    .x_collection_card p {
                        margin: 14px 0 0;
                        color: #555;
                        line-height: 1.65;
                    }
                    .x_collection_action {
                        display: inline-flex;
                        align-items: center;
                        margin-top: 24px;
                        font-weight: 950;
                        text-transform: uppercase;
                    }
                    @media (max-width: 840px) {
                        .x_collections_grid {
                            grid-template-columns: 1fr;
                        }
                    }
                </style>
                <section class="x_collections_hero">
                    <div class="x_collections_inner">
                        <p class="x_collections_eyebrow" t-out="'SUN COLLECTIONS' if is_english else 'SUN 产品系列'"/>
                        <h1 t-out="'Collections' if is_english else '产品系列'"/>
                        <p t-out="'Browse products by collection and choose the right equipment family before selecting size, color, and flex.' if is_english else '按产品系列浏览商品，先选择装备类别，再进入颜色、尺码和硬度等规格。'"/>
                    </div>
                </section>
                <section class="x_collections_inner">
                    <div id="oe_structure_collections_top" class="oe_structure oe_empty"/>
                    <div class="x_collections_grid">
                        <a t-foreach="collections" t-as="collection" class="x_collection_card" t-att-href="collection['url']">
                            <span>
                                <h2 t-out="collection['title']"/>
                                <p t-out="collection['subtitle']"/>
                                <span class="x_collection_action" t-out="'View Collection' if is_english else '查看系列'"/>
                            </span>
                        </a>
                    </div>
                    <div id="oe_structure_collections_bottom" class="oe_structure oe_empty"/>
                </section>
            </main>
        </t>
    </template>
</odoo>
