<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_website_payment_receipt" model="ir.actions.report">
        <field name="name">网站支付收据</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_subwarehouse_hierarchy.report_website_payment_receipt</field>
        <field name="report_file">stock_subwarehouse_hierarchy.report_website_payment_receipt</field>
    </record>

    <template id="report_website_payment_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="payment">
                <t t-set="tx" t-value="payment.payment_transaction_id"/>
                <t t-set="order" t-value="tx.sale_order_ids[:1]"/>
                <t t-set="is_english" t-value="order and order.x_website_checkout_language == 'en_US'"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <div>
                                <h2 class="mb-1" t-out="'Payment Receipt' if is_english else '支付收据'"/>
                                <p class="text-muted mb-0" t-out="'Payment confirmation' if is_english else '支付确认'"/>
                            </div>
                            <div class="text-end">
                                <strong t-out="payment.name"/>
                                <div class="text-muted" t-field="payment.date"/>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-6">
                                <strong t-out="'Customer' if is_english else '客户'"/>
                                <div t-out="payment.partner_id.name"/>
                                <div t-if="payment.partner_id.email" t-out="payment.partner_id.email"/>
                                <div t-if="payment.partner_id.phone" t-out="payment.partner_id.phone"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong t-out="'Payment information' if is_english else '支付信息'"/>
                                <div><t t-out="'Order number: ' if is_english else '订单号：'"/><span t-out="order.name if order else '-'"/></div>
                                <div><t t-out="'Payment method: ' if is_english else '支付方式：'"/><span t-out="tx.provider_id.name if tx else '-'"/></div>
                                <div><t t-out="'Transaction reference: ' if is_english else '微信交易号：'"/><span t-out="tx.provider_reference if tx else '-'"/></div>
                            </div>
                        </div>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th t-out="'Product' if is_english else '商品'"/>
                                    <th class="text-end" t-out="'Quantity' if is_english else '数量'"/>
                                    <th class="text-end" t-out="'Unit price' if is_english else '单价'"/>
                                    <th class="text-end" t-out="'Amount' if is_english else '金额'"/>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="order">
                                    <tr t-foreach="order.order_line" t-as="line" t-if="not line.display_type">
                                        <td t-out="line.product_id.product_tmpl_id._get_website_display_name(is_english) if line.product_id else line.name"/>
                                        <td class="text-end" t-out="line.product_uom_qty"/>
                                        <td class="text-end"><span t-field="line.price_unit" t-options="{'widget': 'monetary', 'display_currency': order.currency_id}"/></td>
                                        <td class="text-end"><span t-field="line.price_total" t-options="{'widget': 'monetary', 'display_currency': order.currency_id}"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end"><strong t-out="'Amount paid' if is_english else '实收金额'"/></td>
                                    <td class="text-end"><strong t-field="payment.amount" t-options="{'widget': 'monetary', 'display_currency': payment.currency_id}"/></td>
                                </tr>
                            </tfoot>
                        </table>
                        <div class="mt-4 pt-3 border-top text-muted small">
                            <t t-out="'This receipt confirms payment only and is not a tax invoice.' if is_english else '本收据用于证明支付已完成，不作为增值税发票使用。'"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="website_payment_receipt" name="Website Payment Receipt">
        <t t-set="is_english" t-value="request.lang and request.lang.code == 'en_US'"/>
        <t t-set="receipt_payment" t-value="order._get_website_payment_receipt()"/>
        <t t-set="receipt_tx" t-value="receipt_payment.payment_transaction_id if receipt_payment else False"/>
        <section t-if="receipt_payment" class="card mt-3" id="website_payment_receipt">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0" t-out="'Payment Receipt' if is_english else '支付收据'"/>
                    <small class="text-muted" t-out="'Payment confirmation' if is_english else '支付确认'"/>
                </div>
                <span class="badge text-bg-success" t-out="'Payment successful' if is_english else '支付成功'"/>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6"><span class="text-muted small d-block" t-out="'Order number' if is_english else '订单号'"/><strong t-out="order.name"/></div>
                    <div class="col-sm-6"><span class="text-muted small d-block" t-out="'Receipt number' if is_english else '收据编号'"/><strong t-out="receipt_payment.name"/></div>
                    <div class="col-sm-6"><span class="text-muted small d-block" t-out="'Payment method' if is_english else '支付方式'"/><strong t-out="receipt_tx.provider_id.name if receipt_tx else '-'"/></div>
                    <div class="col-sm-6"><span class="text-muted small d-block" t-out="'Transaction reference' if is_english else '微信交易号'"/><strong t-out="receipt_tx.provider_reference if receipt_tx else '-'"/></div>
                    <div class="col-sm-6"><span class="text-muted small d-block" t-out="'Payment time' if is_english else '支付时间'"/><strong t-field="receipt_payment.date"/></div>
                    <div class="col-sm-6"><span class="text-muted small d-block" t-out="'Amount paid' if is_english else '实付金额'"/><strong t-field="receipt_payment.amount" t-options="{'widget': 'monetary', 'display_currency': receipt_payment.currency_id}"/></div>
                </div>
                <a class="btn btn-primary mt-4" t-attf-href="/shop/payment/receipt/#{order.id}?access_token=#{order.access_token}">
                    <i class="fa fa-download me-2"/><t t-out="'Download payment receipt PDF' if is_english else '下载支付收据 PDF'"/>
                </a>
                <p class="text-muted small mt-3 mb-0" t-out="'This receipt confirms payment and is not a tax invoice.' if is_english else '支付收据不作为增值税发票使用。'"/>
            </div>
        </section>
    </template>

    <template id="website_sale_confirmation_receipt" inherit_id="website_sale.confirmation">
        <xpath expr="//t[@t-call='website_sale.payment_confirmation_status']" position="after">
            <t t-call="stock_subwarehouse_hierarchy.website_payment_receipt"/>
        </xpath>
    </template>

    <template id="website_sale_payment_stock_hold" inherit_id="website_sale.payment">
        <xpath expr="//div[@id='payment_method']" position="before">
            <t t-if="website_sale_order.x_website_stock_reservation_expiry_epoch">
                <t t-set="is_english" t-value="request.lang and request.lang.code == 'en_US'"/>
                <section class="alert alert-info d-flex align-items-center justify-content-between gap-3" id="x_website_stock_hold" t-att-data-expiry-epoch="website_sale_order.x_website_stock_reservation_expiry_epoch" t-att-data-expired-message="'Reservation expired. Please refresh it.' if is_english else '已到期，请刷新库存保留。'">
                    <div>
                        <strong t-out="'Your stock is reserved' if is_english else '库存已为您保留'"/>
                        <span class="ms-2 text-muted"><t t-out="'Please complete payment within ' if is_english else '请在 '"/><strong class="x_stock_hold_timer">15:00</strong><t t-out="'.' if is_english else ' 内完成支付。'"/></span>
                    </div>
                    <a class="btn btn-outline-secondary btn-sm" href="/shop/payment" t-out="'Refresh reservation' if is_english else '刷新库存保留'"/>
                </section>
                <script type="text/javascript">
                    <![CDATA[
                    (function () {
                        const hold = document.getElementById("x_website_stock_hold");
                        if (!hold) return;
                        const expiry = Number(hold.dataset.expiryEpoch || 0);
                        const timer = hold.querySelector(".x_stock_hold_timer");
                        const refresh = function () {
                            const seconds = Math.max(0, Math.ceil((expiry - Date.now()) / 1000));
                            const minutes = Math.floor(seconds / 60);
                            const remainder = String(seconds % 60).padStart(2, "0");
                            timer.textContent = `${minutes}:${remainder}`;
                            if (!seconds) {
                                hold.classList.remove("alert-info");
                                hold.classList.add("alert-warning");
                                timer.textContent = hold.dataset.expiredMessage;
                                return;
                            }
                            window.setTimeout(refresh, 1000);
                        };
                        refresh();
                    })();
                    ]]>
                </script>
            </t>
        </xpath>
    </template>
</odoo>
