<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_website_payment_refund_wizard_form" model="ir.ui.view">
        <field name="name">stock.subwarehouse.website.payment.refund.wizard.form</field>
        <field name="model">stock.subwarehouse.website.payment.refund.wizard</field>
        <field name="arch" type="xml">
            <form string="微信退款">
                <group>
                    <field name="order_id"/>
                    <field name="transaction_id"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="amount_available" widget="monetary"/>
                    <field name="amount_to_refund" widget="monetary"/>
                </group>
                <div class="alert alert-info" role="alert">
                    退款会提交至微信支付；只有收到微信支付的成功确认后，ERP 才会将退款标记为完成。
                </div>
                <footer>
                    <button name="action_submit_refund" type="object" string="提交退款" class="btn-primary"/>
                    <button string="取消" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
