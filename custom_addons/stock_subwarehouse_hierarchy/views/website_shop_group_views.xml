<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_publish_products_to_shop" model="ir.actions.server">
        <field name="name">发布到网店</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">records.action_publish_to_shop()</field>
    </record>

    <record id="action_unpublish_products_from_shop" model="ir.actions.server">
        <field name="name">从网店下架</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">records.action_unpublish_from_shop()</field>
    </record>

    <record id="product_template_list_shop_group_fields" model="ir.ui.view">
        <field name="name">product.template.list.shop.group.fields</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="account.product_template_list_view_sellable_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="website_published" string="已发布" optional="show"/>
                <field name="x_shop_group_variant_count" string="同名规格数" optional="show"/>
            </xpath>
        </field>
    </record>

    <template id="products_item_shop_group_summary" inherit_id="website_sale.products_item" name="Shop product group summary">
        <xpath expr="//h2[hasclass('o_wsale_products_item_title')]" position="after">
            <t t-set="shop_group_summary" t-value="product.sudo()._get_shop_group_summary()"/>
            <div t-if="shop_group_summary and not x_segmented_shop_page" class="text-muted small mt-1" t-out="shop_group_summary"/>
        </xpath>
    </template>

    <template id="shop_product_buttons_remove_quick_cart" inherit_id="website_sale.shop_product_buttons" name="Remove product card quick cart button">
        <xpath expr="//button[hasclass('o_wsale_product_btn_primary')]" position="replace"/>
    </template>

    <template id="segmented_shop_page_hide_filters" inherit_id="website_sale.products" name="Segmented shop pages without filters">
        <xpath expr="//aside[@id='products_grid_before']" position="attributes">
            <attribute name="t-if">hasLeftColumn and not x_segmented_shop_page</attribute>
        </xpath>
        <xpath expr="//header[@id='o_wsale_products_header']" position="attributes">
            <attribute name="t-if">not x_segmented_shop_page</attribute>
        </xpath>
        <xpath expr="//div[@id='products_grid']" position="before">
            <style t-if="x_segmented_shop_page">
                #products_grid_before,
                #o_wsale_categories_filmstrip,
                #o_wsale_products_header,
                #o_wsale_price_range_option,
                #o_wsale_price_range_option_inner,
                [id*="o_wsale_price_range_option"],
                .products_attributes_filters {
                    display: none !important;
                }
                .o_wsale_products_grid_table {
                    gap: 28px !important;
                }
                .o_wsale_product_grid_wrapper {
                    border: 0 !important;
                    box-shadow: none !important;
                    background: #fff;
                }
                .o_wsale_product_grid_wrapper .oe_product_cart,
                .o_wsale_product_grid_wrapper article {
                    border: 0 !important;
                    border-radius: 0 !important;
                    background: #fff;
                }
                .o_wsale_product_grid_wrapper img {
                    background: #f6f6f6;
                }
                .o_wsale_products_item_title {
                    font-size: .92rem !important;
                    font-weight: 800 !important;
                    letter-spacing: .02em;
                    text-transform: uppercase;
                }
                .o_wsale_product_information {
                    padding-top: 14px;
                }
                .o_wsale_product_sub .oe_currency_value,
                .o_wsale_product_sub .oe_price {
                    font-weight: 800;
                    color: #111;
                }
            </style>
        </xpath>
    </template>

    <template id="product_page_shop_group_siblings" inherit_id="website_sale.product" name="Same-name shop variants">
        <xpath expr="//t[@name='variant_info']" position="after">
            <t t-set="shop_group_siblings" t-value="product.sudo()._get_shop_group_siblings()"/>
            <t t-set="shop_group_variant_rows" t-value="product.sudo()._get_shop_group_variant_rows()"/>
            <t t-set="shop_group_option_groups" t-value="product.sudo()._get_shop_group_variant_option_groups()"/>
            <t t-set="current_variant_values" t-value="product.sudo()._get_shop_variant_display_values()"/>
            <t t-set="current_shop_available" t-value="product.sudo()._is_shop_available()"/>
            <div
                t-if="len(shop_group_siblings) &gt; 1"
                class="o_wsale_product_details_content_section mb-4 o_shop_group_variant_selector"
                t-att-data-current-product-id="product.id"
            >
                <style>
                    .o_shop_group_variant_selector .o_shop_variant_choice {
                        min-width: 4.8rem;
                        min-height: 3.25rem;
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        font-weight: 700;
                        color: #111;
                        background: #f7f7f7;
                        border-color: #f7f7f7 !important;
                        transition: border-color .15s ease, background-color .15s ease, color .15s ease;
                    }
                    .o_shop_group_variant_selector .o_shop_variant_choice_input:checked + .o_shop_variant_choice {
                        border-color: #111 !important;
                        background: #111;
                        color: #fff;
                    }
                    .o_shop_group_variant_selector .fw-semibold {
                        font-size: .9rem;
                        font-weight: 800 !important;
                        color: #111;
                    }
                    .o_shop_unavailable_cta {
                        pointer-events: none;
                        opacity: 1;
                    }
                </style>
                <div
                    t-foreach="shop_group_option_groups"
                    t-as="option_group"
                    class="mb-3"
                >
                    <div class="fw-semibold mb-2" t-out="option_group['label']"/>
                    <div class="d-flex flex-wrap gap-2">
                        <t t-foreach="option_group['values']" t-as="option_value">
                            <t
                                t-set="option_input_id"
                                t-value="'o_shop_variant_%s_%s' % (option_group['key'], option_value)"
                            />
                            <input
                                type="radio"
                                class="btn-check o_shop_variant_choice_input"
                                t-att-name="'o_shop_variant_%s' % option_group['key']"
                                t-att-id="option_input_id"
                                t-att-value="option_value"
                                t-att-data-option-key="option_group['key']"
                                t-att-checked="option_value == current_variant_values.get(option_group['key'])"
                                autocomplete="off"
                            />
                            <label
                                class="btn btn-light border rounded-0 px-3 py-2 o_shop_variant_choice"
                                t-att-for="option_input_id"
                                t-out="option_value"
                            />
                        </t>
                    </div>
                </div>
                <div class="d-none o_shop_group_variant_map">
                    <span
                        t-foreach="shop_group_variant_rows"
                        t-as="variant_row"
                        t-att-data-product-id="variant_row['product'].id"
                        t-att-data-url="variant_row['product']._get_product_url(category)"
                        t-att-data-color="variant_row['values']['color']"
                        t-att-data-size="variant_row['values']['size']"
                        t-att-data-flex="variant_row['values']['flex']"
                        t-att-data-available="'1' if variant_row['is_available'] else '0'"
                        t-att-data-quantity="variant_row['available_quantity']"
                    />
                </div>
                <script>
                    <![CDATA[
                    (function () {
                        const root = document.currentScript.closest(".o_shop_group_variant_selector");
                        if (!root) {
                            return;
                        }
                        let defaultCartText = "";

                        function getCartButtons() {
                            const addToCart = document.querySelector(".x_shop_add_to_cart_button");
                            const unavailable = document.querySelector(".x_shop_unavailable_button");
                            if (addToCart && !defaultCartText) {
                                defaultCartText = addToCart.textContent.trim();
                            }
                            return { addToCart, unavailable };
                        }

                        function selectedValue(key) {
                            const input = root.querySelector(`input[data-option-key="${key}"]:checked`);
                            return input ? input.value : "";
                        }

                        function findSelectedVariant() {
                            const color = selectedValue("color");
                            const size = selectedValue("size");
                            const flex = selectedValue("flex");
                            return Array.from(root.querySelectorAll(".o_shop_group_variant_map [data-product-id]")).find((entry) => {
                                return entry.dataset.color === color
                                    && entry.dataset.size === size
                                    && entry.dataset.flex === flex;
                            });
                        }

                        function setCartAvailability(isAvailable) {
                            const { addToCart, unavailable } = getCartButtons();
                            if (!addToCart || !unavailable) {
                                return;
                            }
                            addToCart.classList.toggle("d-none", !isAvailable);
                            unavailable.classList.toggle("d-none", isAvailable);
                            if (isAvailable) {
                                addToCart.textContent = defaultCartText || "加入购物车";
                            }
                        }

                        function refreshSelection(redirect) {
                            const variant = findSelectedVariant();
                            if (!variant) {
                                setCartAvailability(false);
                                return;
                            }
                            const isAvailable = variant.dataset.available === "1";
                            if (redirect && variant.dataset.productId !== root.dataset.currentProductId) {
                                window.location.href = variant.dataset.url;
                                return;
                            }
                            setCartAvailability(isAvailable);
                        }

                        root.addEventListener("change", function (event) {
                            if (event.target.matches(".o_shop_variant_choice_input")) {
                                refreshSelection(true);
                            }
                        });
                        refreshSelection(false);
                        window.addEventListener("load", function () {
                            refreshSelection(false);
                        });
                        window.requestAnimationFrame(function () {
                            refreshSelection(false);
                        });
                    })();
                    ]]>
                </script>
            </div>
        </xpath>
    </template>

    <template id="product_page_replace_add_to_cart_button" inherit_id="website_sale.cta_wrapper" name="Custom stock-aware add to cart button">
        <xpath expr="//a[@id='add_to_cart']" position="replace">
            <t t-set="current_shop_available" t-value="product.sudo()._is_shop_available()"/>
            <button
                type="button"
                t-attf-class="btn btn-primary flex-grow-1 x_shop_add_to_cart_button {{'' if current_shop_available else 'd-none'}}"
                t-att-data-product-template-id="product.id"
                t-att-data-product-id="product.product_variant_id.id"
                t-att-data-show-quantity="is_view_active('website_sale.product_quantity')"
            >
                <i class="fa fa-shopping-cart me-2"/>
                加入购物车
            </button>
            <button
                type="button"
                disabled="disabled"
                t-attf-class="btn btn-primary flex-grow-1 x_shop_unavailable_button {{'d-none' if current_shop_available else ''}}"
            >
                库存不足，无法加入购物车
            </button>
        </xpath>
    </template>

    <template id="product_page_hide_standard_product_attributes" inherit_id="website_sale.product" name="Hide standard shop attributes">
        <xpath expr="//t[@name='variant_info']" position="before">
            <t
                t-set="shop_section_url"
                t-value="{'ski': '/ski-products', 'snowboard': '/snowboard-products', 'other': '/other-products'}.get(product.sudo()._get_shop_product_family(), '/other-products')"
            />
            <span class="d-none x_shop_product_section" t-att-data-shop-section-url="shop_section_url"/>
            <style>
                .o_wsale_breadcrumb {
                    display: none !important;
                }
                .o_wsale_product_page #o_wsale_product_details_content {
                    max-width: 560px;
                }
                .o_wsale_product_page .o_wsale_product_details_content_section_title h1,
                .o_wsale_product_page h1[itemprop="name"] {
                    font-size: 1.65rem;
                    line-height: 1.15;
                    font-weight: 900;
                    letter-spacing: .02em;
                    text-transform: uppercase;
                }
                .o_wsale_product_page .product_price .oe_price {
                    font-size: 1.4rem;
                    font-weight: 900;
                    color: #111;
                }
                .o_wsale_product_page .o_wsale_product_details_content_section {
                    border: 0 !important;
                }
                .x_shop_add_to_cart_button,
                .x_shop_unavailable_button {
                    min-height: 3.8rem;
                    border-radius: 0;
                    border-color: #111;
                    background: #111;
                    color: #fff !important;
                    font-weight: 900;
                    letter-spacing: .03em;
                    text-transform: uppercase;
                }
                .x_shop_add_to_cart_button:hover {
                    background: #333;
                    border-color: #333;
                    color: #fff !important;
                }
                .x_shop_unavailable_button:disabled {
                    opacity: 1;
                }
                #product_detail.css_not_available .css_quantity,
                #product_detail .css_not_available.js_product .css_quantity {
                    display: inline-flex !important;
                }
                #product_detail.css_not_available .oe_price,
                #product_detail.css_not_available .oe_default_price,
                #product_detail .css_not_available.js_product .oe_price,
                #product_detail .css_not_available.js_product .oe_default_price {
                    display: inline !important;
                }
                #product_detail .css_not_available_msg {
                    display: none !important;
                }
                #product_detail .variant_attribute label.css_not_available,
                #product_detail .variant_attribute .o_variant_pills.css_not_available,
                #product_detail label.css_attribute_color.css_not_available,
                #product_detail input.css_not_available,
                #product_detail option.css_not_available {
                    opacity: 1 !important;
                }
                #product_detail label.css_attribute_color.css_not_available:after {
                    display: none !important;
                }
                #product_attributes_simple {
                    display: none !important;
                }
            </style>
            <script>
                <![CDATA[
                (function () {
                    function getQuantity() {
                        const input = document.querySelector("#product_detail input[name='add_qty']");
                        const quantity = input ? parseInt(input.value || "1", 10) : 1;
                        return Number.isFinite(quantity) && quantity > 0 ? quantity : 1;
                    }

                    async function addSelectedProductToCart(event) {
                        const button = event.currentTarget;
                        if (button.classList.contains("d-none")) {
                            return;
                        }
                        button.disabled = true;
                        try {
                            const response = await fetch("/shop/cart/add", {
                                method: "POST",
                                headers: {
                                    "Content-Type": "application/json",
                                    "X-Requested-With": "XMLHttpRequest",
                                },
                                body: JSON.stringify({
                                    jsonrpc: "2.0",
                                    method: "call",
                                    params: {
                                        product_template_id: parseInt(button.dataset.productTemplateId, 10),
                                        product_id: parseInt(button.dataset.productId, 10),
                                        quantity: getQuantity(),
                                    },
                                }),
                            });
                            const payload = await response.json();
                            if (!response.ok || payload.error) {
                                throw new Error(payload.error?.data?.message || payload.error?.message || "Add to cart failed");
                            }
                            window.location.href = "/shop/cart";
                        } catch (error) {
                            button.disabled = false;
                            window.alert("加入购物车失败，请稍后再试。");
                        }
                    }

                    function setupCustomCartButton() {
                        const button = document.querySelector(".x_shop_add_to_cart_button");
                        if (button && !button.dataset.boundCustomCart) {
                            button.dataset.boundCustomCart = "1";
                            button.addEventListener("click", addSelectedProductToCart);
                        }
                    }

                    function keepSearchInProductSection() {
                        const section = document.querySelector(".x_shop_product_section");
                        const sectionUrl = section ? section.dataset.shopSectionUrl : "";
                        if (!sectionUrl) {
                            return;
                        }
                        document.querySelectorAll(".o_wsale_products_searchbar_form").forEach((form) => {
                            form.setAttribute("action", sectionUrl);
                        });
                    }

                    function openDiscussion() {
                        const discussionContent = document.querySelector("#o_product_page_reviews_content");
                        const discussionTitle = document.querySelector("[data-bs-target='#o_product_page_reviews_content']");
                        if (discussionContent) {
                            discussionContent.classList.add("show");
                        }
                        if (discussionTitle) {
                            discussionTitle.classList.remove("collapsed");
                            discussionTitle.setAttribute("aria-expanded", "true");
                        }
                    }
                    setupCustomCartButton();
                    keepSearchInProductSection();
                    openDiscussion();
                    window.addEventListener("load", function () {
                        setupCustomCartButton();
                        keepSearchInProductSection();
                        openDiscussion();
                    });
                    window.requestAnimationFrame(function () {
                        setupCustomCartButton();
                        keepSearchInProductSection();
                        openDiscussion();
                    });
                })();
                ]]>
            </script>
        </xpath>
    </template>

    <template id="product_page_hide_managed_custom_variants" inherit_id="website_sale.variants" name="Hide managed custom shop variants">
        <xpath expr="//t[@t-set='has_configurable_attribute_line']" position="attributes">
            <attribute name="t-value">any(ptal._is_configurable() for ptal in product._get_visible_website_attribute_lines())</attribute>
        </xpath>
        <xpath expr="//t[@t-foreach='product.valid_product_template_attribute_line_ids']" position="attributes">
            <attribute name="t-foreach">product._get_visible_website_attribute_lines()</attribute>
        </xpath>
    </template>

    <template id="product_page_open_discussion_by_default" inherit_id="website_sale.product_comment" name="Open product discussion by default" active="True">
        <xpath expr="//a[@data-bs-target='#o_product_page_reviews_content']" position="attributes">
            <attribute name="class">o_product_page_reviews_title d-flex justify-content-between text-reset text-decoration-none</attribute>
            <attribute name="aria-expanded">true</attribute>
        </xpath>
        <xpath expr="//div[@id='o_product_page_reviews_content']" position="attributes">
            <attribute name="class">collapse show mt-3</attribute>
        </xpath>
    </template>
</odoo>
